---
import type {MarkdownHeading} from "astro";

interface Props {
  headings: MarkdownHeading[];
  minDepth?: number;
  maxDepth?: number;
}

const {headings, minDepth = 2, maxDepth = 4} = Astro.props;

const visible = headings.filter(
  (heading) => heading.depth >= minDepth && heading.depth <= maxDepth,
);

const minVisibleDepth = visible.reduce(
  (lowest, heading) => Math.min(lowest, heading.depth),
  maxDepth,
);
---

{visible.length > 0 && (
  <nav class="docs-toc-nav" aria-label="On this page">
    <p class="docs-toc-eyebrow">On this page</p>
    <ol class="docs-toc-list">
      {visible.map((heading) => (
        <li
          class={`docs-toc-item docs-toc-item-d${heading.depth - minVisibleDepth}`}
          data-toc-anchor={heading.slug}
        >
          <a class="docs-toc-link" href={`#${heading.slug}`}>
            <span>{heading.text}</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
