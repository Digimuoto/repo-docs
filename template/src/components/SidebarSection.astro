---
import type {SidebarSection as SidebarSectionType} from "../lib/navigation";
import SidebarNode from "./SidebarNode.astro";

interface Props {
  currentPath: string;
  section: SidebarSectionType;
}

const {currentPath, section} = Astro.props;

// An active child anywhere inside the section forces the section open
// regardless of user-stored collapse state.
function stripTrailingSlash(value: string) {
  if (value === "/") {
    return "/";
  }
  return value.endsWith("/") ? value.slice(0, -1) : value;
}

function hasActiveDescendant(items: typeof section.items): boolean {
  const current = stripTrailingSlash(currentPath);
  function walk(node: (typeof items)[number]): boolean {
    if (node.href && stripTrailingSlash(node.href) === current) {
      return true;
    }
    return node.children.some(walk);
  }
  return items.some(walk);
}

const activePath = hasActiveDescendant(section.items);
const sectionOpen = activePath;
---

{section.label ? (
  <section class="docs-nav-section">
    <button
      type="button"
      class="docs-nav-section-toggle"
      data-nav-toggle={section.key}
      aria-expanded={sectionOpen ? "true" : "false"}
    >
      <svg
        class="docs-nav-chevron docs-nav-chevron-section"
        viewBox="0 0 12 12"
        aria-hidden="true"
      >
        <path
          d="M4.5 3L8 6l-3.5 3"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <span>{section.label}</span>
    </button>
    <ul
      class="docs-nav-list"
      data-nav-children-of={section.key}
      data-nav-open={sectionOpen ? "true" : "false"}
      data-nav-active-path={activePath ? "true" : "false"}
    >
      {section.items.map((node) => (
        <SidebarNode currentPath={currentPath} node={node} />
      ))}
    </ul>
  </section>
) : (
  <section class="docs-nav-section docs-nav-section-unlabeled">
    <ul class="docs-nav-list docs-nav-list-root" data-nav-root="true">
      {section.items.map((node) => (
        <SidebarNode currentPath={currentPath} node={node} />
      ))}
    </ul>
  </section>
)}
