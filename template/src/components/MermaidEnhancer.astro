<script>
  if (document.body.dataset.docsMermaid === "true") {
    const sourceNodes = Array.from(
      document.querySelectorAll(
        "pre[data-language='mermaid'] > code, pre > code.language-mermaid, pre > code.lang-mermaid",
      ),
    );

    if (sourceNodes.length > 0) {
      const {default: mermaid} = await import("mermaid");
      const docsState =
        (window as any).__repoDocsState ??
        ((window as any).__repoDocsState = {
          buttons: [] as {updateLabel: () => void}[],
          fullscreenInstalled: false,
        });

      // Each entry caches the source text + the diagram <div> so we
      // can re-render after a mode change without losing the original
      // markup (Mermaid replaces textContent with an SVG on first run).
      type DiagramEntry = {diagram: HTMLElement; source: string};
      const diagrams: DiagramEntry[] = [];
      const buttons: {updateLabel: () => void}[] = [];

      sourceNodes.forEach((node) => {
        const pre = node.closest("pre");
        if (!pre) {
          return;
        }

        const wrapper = document.createElement("div");
        wrapper.className = "mermaid-card not-prose";

        const toolbar = document.createElement("div");
        toolbar.className = "mermaid-toolbar";

        const button = document.createElement("button");
        button.type = "button";
        button.className = "mermaid-expand-button";
        button.textContent = "Fullscreen";

        const source = node.textContent ?? "";
        const diagram = document.createElement("div");
        diagram.className = "mermaid";
        diagram.textContent = source;

        const updateLabel = () => {
          button.textContent =
            document.fullscreenElement === wrapper ? "Exit fullscreen" : "Fullscreen";
        };

        button.addEventListener("click", async () => {
          if (document.fullscreenElement === wrapper) {
            await document.exitFullscreen();
            return;
          }

          if (wrapper.requestFullscreen) {
            await wrapper.requestFullscreen();
          }
        });

        toolbar.appendChild(button);
        wrapper.appendChild(toolbar);
        wrapper.appendChild(diagram);
        pre.replaceWith(wrapper);
        diagrams.push({diagram, source});
        buttons.push({updateLabel});
      });

      docsState.buttons = buttons;

      if (!docsState.fullscreenInstalled) {
        document.addEventListener("fullscreenchange", () => {
          docsState.buttons.forEach(({updateLabel}: {updateLabel: () => void}) => updateLabel());
        });
        docsState.fullscreenInstalled = true;
      }

      docsState.buttons.forEach(({updateLabel}: {updateLabel: () => void}) => updateLabel());

      // Slate-specific Mermaid palette: base theme + tuned themeVariables
      // calibrated for the lifted-dark canvas. Other themes keep
      // Mermaid's stock dark / default (which already sit in the
      // github-dark / github-light family).
      const slateThemeVariables = {
        background: "#2d333b",
        mainBkg: "#383f5e",
        secondBkg: "#2f4a4a",
        tertiaryBkg: "#4a3f2f",

        primaryColor: "#383f5e",
        primaryTextColor: "#cdd9e5",
        primaryBorderColor: "#5a6493",

        secondaryColor: "#2f4a4a",
        secondaryTextColor: "#cdd9e5",
        secondaryBorderColor: "#4d7a78",

        tertiaryColor: "#4a3f2f",
        tertiaryTextColor: "#cdd9e5",
        tertiaryBorderColor: "#7a6948",

        lineColor: "#768390",
        textColor: "#cdd9e5",

        // Sequence diagram
        actorBkg: "#383f5e",
        actorBorder: "#5a6493",
        actorTextColor: "#cdd9e5",
        actorLineColor: "#545d68",
        signalColor: "#adbac7",
        signalTextColor: "#cdd9e5",
        labelBoxBkgColor: "#2f4a4a",
        labelBoxBorderColor: "#4d7a78",
        labelTextColor: "#cdd9e5",
        loopTextColor: "#cdd9e5",
        noteBkgColor: "#4a3f2f",
        noteBorderColor: "#7a6948",
        noteTextColor: "#cdd9e5",
        activationBkgColor: "#4a323e",
        activationBorderColor: "#7a525f",
        sequenceNumberColor: "#cdd9e5",

        // State diagram cycle (Mermaid uses fillType0..7)
        fillType0: "#383f5e",
        fillType1: "#2f4a4a",
        fillType2: "#4a3f2f",
        fillType3: "#4a323e",
        fillType4: "#3a4a3a",
        fillType5: "#383f5e",
        fillType6: "#2f4a4a",
        fillType7: "#4a3f2f",
      };

      function buildConfig() {
        const activeTheme = document.documentElement.dataset.theme;
        const isDark = document.documentElement.classList.contains("dark");
        if (activeTheme === "cortex-slate") {
          return {theme: "base" as const, themeVariables: slateThemeVariables};
        }
        return {theme: isDark ? ("dark" as const) : ("default" as const)};
      }

      let renderToken = 0;
      async function renderAll() {
        // Bump the token so any in-flight render from a previous mode
        // toggle bails out before clobbering the freshly-rendered SVG.
        const token = ++renderToken;
        mermaid.initialize({
          securityLevel: "strict",
          startOnLoad: false,
          ...buildConfig(),
        });
        // Use mermaid.render() rather than .run() so we get fresh SVG
        // markup back (v11 caches IDs internally and .run() can skip
        // already-processed nodes even after we wipe their content).
        // Each call needs a unique id; we mix the iteration index +
        // token so re-renders don't collide.
        await Promise.all(
          diagrams.map(async (entry, index) => {
            const id = `mermaid-diagram-${index}-${token}`;
            try {
              const {svg, bindFunctions} = await mermaid.render(id, entry.source);
              if (token !== renderToken) return; // newer render in flight
              entry.diagram.innerHTML = svg;
              if (bindFunctions) {
                bindFunctions(entry.diagram);
              }
            } catch (err) {
              console.warn("[mermaid] render failed:", err);
            }
          }),
        );
      }

      await renderAll();

      // Re-render whenever the reader flips the colour mode so SVGs
      // pick up the new theme's palette (CSS overrides alone can't
      // change Mermaid's baked-in inline fills for non-slate themes).
      // Watch <html> attribute changes too as a belt-and-braces fallback
      // in case the custom event misses (e.g. system colour-scheme flip
      // while the page is open).
      document.addEventListener("repodocs:mode-change", () => {
        void renderAll();
      });

      let lastTheme = document.documentElement.dataset.theme;
      const observer = new MutationObserver(() => {
        const next = document.documentElement.dataset.theme;
        if (next !== lastTheme) {
          lastTheme = next;
          void renderAll();
        }
      });
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });
    }
  }
</script>
