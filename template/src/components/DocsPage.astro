---
import type {MarkdownHeading} from "astro";
import {getCollection, render} from "astro:content";
import fs from "node:fs";
import path from "node:path";
import DocsLayout from "../layouts/DocsLayout.astro";
import DocsMetaBlock from "./DocsMetaBlock.astro";
import DocsReadingSequence from "./DocsReadingSequence.astro";
import DocsTitle from "./DocsTitle.astro";
import {deriveDocKind} from "../lib/doc-kind";
import {buildSidebar, findReadingSequence, normalizeEntryId} from "../lib/navigation";
import {siteConfig, withBasePath} from "../lib/site-config";

// Lean theory pages get their headings from the Verso fragment, not
// from Astro's markdown render — the staged .md file is just a stub.
// Parse <h2-h4> tags from the fragment HTML so the TOC sidebar still
// works on dense Lean pages (long files with /-! ## Section -/ breaks
// benefit from on-page navigation just as much as long markdown).
const VERSO_HEADING_RE = /<(h[1-6])\b[^>]*\bid="([^"]+)"[^>]*>([\s\S]*?)<\/\1>/g;
function extractVersoHeadings(html: string | null): MarkdownHeading[] {
  if (!html) return [];
  const headings: MarkdownHeading[] = [];
  let match: RegExpExecArray | null;
  VERSO_HEADING_RE.lastIndex = 0;
  while ((match = VERSO_HEADING_RE.exec(html)) !== null) {
    const tag = match[1].toLowerCase();
    const slug = match[2];
    const text = match[3]
      .replace(/<[^>]+>/g, " ")
      .replace(/&amp;/g, "&")
      .replace(/&lt;/g, "<")
      .replace(/&gt;/g, ">")
      .replace(/\s+/g, " ")
      .trim();
    if (!text) continue;
    headings.push({depth: parseInt(tag.slice(1), 10), text, slug});
  }
  return headings;
}

const allDocs = await getCollection("docs", ({data}) => !data.draft);
const navigation = buildSidebar(allDocs);
const {doc} = Astro.props;
const {Content, headings: markdownHeadings} = await render(doc);
const versoFragmentPath = doc.data.verso?.fragment
  ? path.resolve(process.cwd(), "src/generated", doc.data.verso.fragment)
  : null;
const versoFragment = versoFragmentPath ? fs.readFileSync(versoFragmentPath, "utf8") : null;
const versoHeadings = extractVersoHeadings(versoFragment);
// Merge: markdown body headings (from the staged stub, usually empty
// for Lean pages) followed by Verso fragment headings (the substantive
// ones for Lean). For non-Lean pages versoHeadings is empty so this
// is a no-op.
const headings: MarkdownHeading[] = [...markdownHeadings, ...versoHeadings];
const docBody = doc.body ?? "";
// Mermaid keywords that can appear at the top of a fenced block. Used
// for Verso-rendered Lean pages, which inline diagrams as bare
// <pre><code>flowchart LR …</code></pre> with no language tag — we can
// only detect them by content.
const VERSO_MERMAID_RE =
  /<pre>\s*<code>\s*(?:flowchart|sequenceDiagram|classDiagram|stateDiagram(?:-v2)?|erDiagram|journey|gantt|pie|gitGraph|mindmap|timeline|quadrantChart|requirementDiagram|sankey-beta|xychart-beta|block-beta|C4(?:Context|Container|Component|Dynamic|Deployment))\b/;
const hasMermaid =
  docBody.includes("```mermaid") ||
  docBody.includes("language-mermaid") ||
  docBody.includes("lang-mermaid") ||
  docBody.includes("data-language=\"mermaid\"") ||
  (versoFragment != null && VERSO_MERMAID_RE.test(versoFragment));
const description = doc.data.description ?? siteConfig.site.description;
const docKind = deriveDocKind(doc);
const typstPdfHref = doc.data.typst?.pdf ? withBasePath(doc.data.typst.pdf) : null;

// Reading-sequence prev/next: derived from the materialised nav tree
// (same order the sidebar shows). Skipped silently for the docs root
// or when the page sits alone in its section.
const docKey = normalizeEntryId(doc.id);
const currentHref = withBasePath(docKey === "index" ? "" : docKey);
const sequence = findReadingSequence(navigation, currentHref);
---

<DocsLayout
  title={doc.data.title}
  description={description}
  navigation={navigation}
  headings={headings}
  hasMermaid={hasMermaid}
  docKind={docKind}
>
  <DocsTitle doc={doc} />
  {typstPdfHref ? (
    <section class="docs-typst-embed not-prose" aria-label={`${doc.data.title} — embedded PDF manuscript`}>
      <div class="docs-typst-embed-actions" role="toolbar" aria-label="Manuscript actions">
        <a class="docs-typst-embed-chip" href={typstPdfHref} target="_blank" rel="noopener noreferrer" title="Open the PDF in a new tab">
          <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M4 8l4-4M5 4h3v3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Open</span>
        </a>
        <a class="docs-typst-embed-chip" href={typstPdfHref} download title="Download the PDF">
          <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M6 2v6.5M3.5 6L6 8.5 8.5 6M3 10h6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Download</span>
        </a>
        <button type="button" class="docs-typst-embed-chip" data-typst-fullscreen title="Toggle fullscreen reading">
          <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M2 4.5V2h2.5M7.5 2H10v2.5M10 7.5V10H7.5M4.5 10H2V7.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span data-typst-fullscreen-label>Fullscreen</span>
        </button>
      </div>
      <div class="docs-typst-embed-frame-wrap" data-typst-frame-wrap>
        <div class="docs-typst-embed-loader" aria-hidden="true">
          <span class="docs-typst-embed-loader-eyebrow">Manuscript</span>
          <span class="docs-typst-embed-loader-title">Loading PDF…</span>
        </div>
        <iframe
          class="docs-typst-embed-frame"
          src={typstPdfHref}
          title={`${doc.data.title} — PDF manuscript`}
          sandbox="allow-same-origin allow-scripts allow-popups"
          loading="lazy"
        ></iframe>
        <div class="docs-typst-embed-fallback" hidden>
          <p class="docs-typst-embed-fallback-text">
            This page embeds a PDF manuscript. Your browser can't display it inline. <a href={typstPdfHref}>Download the PDF</a> or <a href={typstPdfHref} target="_blank" rel="noopener noreferrer">open it in a new tab</a>.
          </p>
        </div>
      </div>
      <script is:inline>
        (() => {
          const wrap = document.querySelector("[data-typst-frame-wrap]");
          if (!wrap) return;
          const iframe = wrap.querySelector(".docs-typst-embed-frame");
          const fallback = wrap.querySelector(".docs-typst-embed-fallback");
          if (iframe) {
            iframe.addEventListener("load", () => {
              wrap.dataset.loaded = "true";
            });
            iframe.addEventListener("error", () => {
              if (fallback) fallback.hidden = false;
              wrap.dataset.failed = "true";
            });
          }

          const fsButton = document.querySelector("[data-typst-fullscreen]");
          const fsLabel = document.querySelector("[data-typst-fullscreen-label]");
          function syncLabel() {
            if (!fsLabel) return;
            fsLabel.textContent = document.fullscreenElement === wrap ? "Exit" : "Fullscreen";
          }
          fsButton?.addEventListener("click", () => {
            if (document.fullscreenElement === wrap) {
              document.exitFullscreen?.();
            } else {
              wrap.requestFullscreen?.();
            }
          });
          document.addEventListener("fullscreenchange", syncLabel);
        })();
      </script>
    </section>
  ) : (
    <Fragment>
      <DocsMetaBlock doc={doc} />
      <Content />
      {versoFragment && <Fragment set:html={versoFragment} />}
      <DocsReadingSequence prev={sequence.prev} next={sequence.next} />
    </Fragment>
  )}
</DocsLayout>
