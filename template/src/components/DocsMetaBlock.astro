---
import type {CollectionEntry} from "astro:content";
import {siteConfig} from "../lib/site-config";

/*
 * Decision-record meta block, rendered between the title display
 * and the doc body whenever a page carries any of:
 *   - status
 *   - superseded_by
 *   - related
 *
 * Path-shaped values (`docs/<site>/<rest>.md`) are resolved into the
 * site's clean URL form. Linear-style ticket IDs (`DIG-NNN`) get a
 * monospace pill. Everything else renders verbatim so authors who
 * write a free-text reference like "see Section 3.2 of Knuth 1974"
 * still see something readable.
 */

interface Props {
  doc: CollectionEntry<"docs">;
}

const {doc} = Astro.props;
const data = doc.data as {
  status?: string;
  superseded_by?: string | null;
  related?: string[];
};

function stripTrailingSlash(value: string) {
  if (value === "/") return "";
  return value.endsWith("/") ? value.slice(0, -1) : value;
}

function repoPathToUrl(raw: string): string | null {
  const trimmed = raw.trim();
  // Match `docs/<anything>/<rest>.md|mdx`. Cortex's frontmatter uses
  // these full-from-repo-root paths so links work in IDE jump-to-file
  // and on GitHub web. We strip `docs/<site>/` because the site's
  // contentDir is exactly that, leaving a content-root-relative slug.
  const match = trimmed.match(/^docs\/[^/]+\/(.+\.(?:md|mdx))$/i);
  if (!match) return null;
  const noExt = match[1].replace(/\.(md|mdx)$/i, "");
  const slug =
    noExt === "index"
      ? ""
      : noExt.endsWith("/index")
      ? noExt.slice(0, -"/index".length)
      : noExt;
  const base = stripTrailingSlash(siteConfig.site.routeBase || "/");
  return slug === "" ? `${base}/` : `${base}/${slug}/`;
}

interface Pointer {
  kind: "doc" | "ticket" | "text";
  label: string;
  href?: string;
}

function classify(item: string): Pointer {
  const trimmed = item.trim();
  if (/^[A-Z][A-Z0-9]+-\d+$/i.test(trimmed)) {
    return {kind: "ticket", label: trimmed.toUpperCase()};
  }
  const docUrl = repoPathToUrl(trimmed);
  if (docUrl) return {kind: "doc", label: trimmed, href: docUrl};
  return {kind: "text", label: trimmed};
}

const status = typeof data.status === "string" ? data.status : null;
const supersededBy =
  typeof data.superseded_by === "string" && data.superseded_by.trim() !== ""
    ? classify(data.superseded_by)
    : null;
const related: Pointer[] = (data.related ?? [])
  .filter((item): item is string => typeof item === "string" && item.trim() !== "")
  .map(classify);

const hasMeta = Boolean(status) || supersededBy !== null || related.length > 0;
const statusClass = status
  ? status.toLowerCase().replace(/[^a-z0-9_-]/g, "-")
  : "";
---

{hasMeta && (
  <aside class={`docs-meta-block ${status ? `docs-meta-block-${statusClass}` : ""}`} aria-label="Document metadata">
    {status && (
      <div class="docs-meta-row">
        <span class="docs-meta-label">Status</span>
        <span class={`docs-meta-status docs-meta-status-${statusClass}`}>
          {status}
        </span>
      </div>
    )}
    {supersededBy && (
      <div class="docs-meta-row">
        <span class="docs-meta-label">Superseded by</span>
        {supersededBy.kind === "doc" && supersededBy.href ? (
          <a class="docs-meta-link" href={supersededBy.href}>{supersededBy.label}</a>
        ) : supersededBy.kind === "ticket" ? (
          <code class="docs-meta-ticket">{supersededBy.label}</code>
        ) : (
          <span class="docs-meta-text">{supersededBy.label}</span>
        )}
      </div>
    )}
    {related.length > 0 && (
      <div class="docs-meta-row">
        <span class="docs-meta-label">Related</span>
        <ul class="docs-meta-related">
          {related.map((item) => (
            <li>
              {item.kind === "doc" && item.href ? (
                <a class="docs-meta-link" href={item.href}>{item.label}</a>
              ) : item.kind === "ticket" ? (
                <code class="docs-meta-ticket">{item.label}</code>
              ) : (
                <span class="docs-meta-text">{item.label}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}
  </aside>
)}
