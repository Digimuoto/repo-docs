---
import type {CollectionEntry} from "astro:content";
import {siteConfig} from "../lib/site-config";

/*
 * Decision-record cross-references.
 *
 * Renders only when the page declares `superseded_by` or `related`
 * in frontmatter — both are unique pieces of information that
 * don't fit anywhere else. Status is deliberately NOT rendered
 * here; it already shows as a pill in the sidebar nav and most
 * docs already write a `## Status` heading in the body.
 *
 * Layout is one wrapping row of compact pills so the block reads
 * as a typographic margin note rather than an info card.
 */

interface Props {
  doc: CollectionEntry<"docs">;
}

const {doc} = Astro.props;
const data = doc.data as {
  superseded_by?: string | null;
  related?: string[];
};

function stripTrailingSlash(value: string) {
  if (value === "/") return "";
  return value.endsWith("/") ? value.slice(0, -1) : value;
}

function repoPathToUrl(raw: string): string | null {
  const trimmed = raw.trim();
  const match = trimmed.match(/^docs\/[^/]+\/(.+\.(?:md|mdx))$/i);
  if (!match) return null;
  const noExt = match[1].replace(/\.(md|mdx)$/i, "");
  const slug =
    noExt === "index"
      ? ""
      : noExt.endsWith("/index")
      ? noExt.slice(0, -"/index".length)
      : noExt;
  const base = stripTrailingSlash(siteConfig.site.routeBase || "/");
  return slug === "" ? `${base}/` : `${base}/${slug}/`;
}

function shortLabel(rawPath: string): string {
  // Strip the docs/<site>/ prefix authors use for portable cross-refs.
  const trimmed = rawPath
    .replace(/\.(md|mdx)$/i, "")
    .replace(/^docs\/[^/]+\//, "");
  // ADR shorthand: adrs/NNNN-… → "ADR NNNN".
  const adr = trimmed.match(/^adrs\/(\d+)-/i);
  if (adr) return `ADR ${adr[1]}`;
  // Otherwise: last path segment, strip leading numeric/date prefix,
  // unkebab. So architecture/03-formalism-stack → "formalism stack".
  const tail = trimmed.split("/").pop() ?? trimmed;
  return tail
    .replace(/^\d{4}-\d{2}-\d{2}-/, "")
    .replace(/^\d+-/, "")
    .replace(/[-_]/g, " ");
}

interface Pointer {
  kind: "doc" | "ticket" | "text";
  label: string;
  title: string;
  href?: string;
}

function classify(item: string): Pointer {
  const trimmed = item.trim();
  if (/^[A-Z][A-Z0-9]+-\d+$/i.test(trimmed)) {
    return {kind: "ticket", label: trimmed.toUpperCase(), title: trimmed};
  }
  const docUrl = repoPathToUrl(trimmed);
  if (docUrl) return {kind: "doc", label: shortLabel(trimmed), title: trimmed, href: docUrl};
  return {kind: "text", label: trimmed, title: trimmed};
}

const supersededBy =
  typeof data.superseded_by === "string" && data.superseded_by.trim() !== ""
    ? classify(data.superseded_by)
    : null;
const related: Pointer[] = (data.related ?? [])
  .filter((item): item is string => typeof item === "string" && item.trim() !== "")
  .map(classify);

const hasMeta = supersededBy !== null || related.length > 0;
---

{hasMeta && (
  <aside class="docs-meta-block" aria-label="Document references">
    {supersededBy && (
      supersededBy.kind === "doc" && supersededBy.href ? (
        <a
          class="docs-meta-pill docs-meta-pill-superseded"
          href={supersededBy.href}
          title={`Superseded by ${supersededBy.title}`}
        >
          superseded by → <span>{supersededBy.label}</span>
        </a>
      ) : (
        <span
          class="docs-meta-pill docs-meta-pill-superseded"
          title={`Superseded by ${supersededBy.title}`}
        >
          superseded by → <span>{supersededBy.label}</span>
        </span>
      )
    )}
    {related.map((item) => {
      if (item.kind === "doc" && item.href) {
        return (
          <a class="docs-meta-pill docs-meta-pill-related" href={item.href} title={item.title}>
            {item.label}
          </a>
        );
      }
      if (item.kind === "ticket") {
        return (
          <span class="docs-meta-pill docs-meta-pill-ticket" title={item.title}>
            {item.label}
          </span>
        );
      }
      return (
        <span class="docs-meta-pill docs-meta-pill-text" title={item.title}>
          {item.label}
        </span>
      );
    })}
  </aside>
)}
